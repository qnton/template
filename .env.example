# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and adjust. .env is git-ignored. Never commit real secrets.
# Config is read with the stdlib only (os.Getenv + small typed helpers).
# ─────────────────────────────────────────────────────────────────────────────

# development | production
# production tightens cookies (Secure + __Host- prefix) and enables HSTS.
APP_ENV=development

# Address the public server listens on.
APP_ADDR=:8080

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# pgx connection string. In docker-compose this points at the `db` service.
DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable

# Host port the compose `db` service is published on (change if 5432 is taken).
DB_PORT=5432

# ── Connection pool (pgxpool) tuning ────────────────────────────────────────
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_PERIOD=1m

# ── HTTP server timeouts / limits ────────────────────────────────────────────
READ_TIMEOUT=10s
READ_HEADER_TIMEOUT=5s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=120s
SHUTDOWN_TIMEOUT=15s
# Max request body size in bytes (defense-in-depth; 1 MiB default).
MAX_REQUEST_BYTES=1048576

# ── App-level rate limit (DEFENSE-IN-DEPTH ONLY) ─────────────────────────────
# The PRIMARY rate-limiting / WAF layer belongs at the Cloudflare edge.
# This token-bucket keys on the real client IP (see TRUSTED_PROXIES).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# ── Real client IP behind a reverse proxy / Cloudflare ───────────────────────
# Client-IP headers (CF-Connecting-IP, X-Forwarded-For) are trusted ONLY when
# the DIRECT peer is inside one of these CIDRs — otherwise the header is spoofable.
# Comma-separated CIDRs. EMPTY (default) = never trust headers, always use the
# direct peer address (safe default; correct when there is no proxy in front).
#
# Behind Cloudflare, set this to Cloudflare's published ranges (verify the live
# list at https://www.cloudflare.com/ips/):
# TRUSTED_PROXIES=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22,2400:cb00::/32,2606:4700::/32,2803:f800::/32,2405:b500::/32,2405:8100::/32,2a06:98c0::/29,2c0f:f248::/32
TRUSTED_PROXIES=

# ── Optional middleware toggles ──────────────────────────────────────────────
# App-level gzip is defense-in-depth; the Cloudflare edge already compresses.
GZIP_ENABLED=true

# ── pprof (profiling) — internal, NON-public listener; OFF by default ────────
PPROF_ENABLED=false
PPROF_ADDR=127.0.0.1:6060
